{
    "buildCommand": "cd frontend && bun run build && cd ../backend && bun run build",
    "outputDirectory": "frontend/dist",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/backend/api/:path*"
        }
    ],
    "functions": {
        "backend/api/index.ts": {
            "runtime": "nodejs18.x"
        }
    }
}
